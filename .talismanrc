# Configuration Talisman pour fonds-prevention-argile
fileignoreconfig:
  - filename: pnpm-lock.yaml
    checksum: 0a7039c7b691236b1cc921629b7814bdf0d29f2afe385c68565b88b6243dc1ae
  - filename: package-lock.json
    checksum: ignore
  - filename: .env.example
    checksum: ignore
  - filename: .env.local.example
    checksum: ignore
  - filename: .github/workflows/ci.yml
    checksum: ignore
  - filename: public/maintenance.html
    checksum: 91ae010cca3a5e892b0fdc9ddef793c2108c228ddb43e3d983d8676b7f35c790

# Seuil de détection élevé pour éviter les faux positifs
threshold: high

# Permettre les valeurs d'exemple utilisées dans la CI
allowed_patterns:
  - "API_KEY_EXAMPLE"
  - "123456"
