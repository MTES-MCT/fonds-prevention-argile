{
  "name": "fonds-prevention-argile",
  "version": "1.13.1",
  "private": true,
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "next build",
    "start": "next start",
    "start:dev": "next dev",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm precommit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "mailhog:start": "docker-compose up -d mailhog",
    "db:start": "docker-compose up -d postgres",
    "db:stop": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d postgres",
    "db:push": "pnpm drizzle-kit push",
    "db:push:force": "pnpm drizzle-kit push --force",
    "db:migrate": "tsx src/shared/database/migrate.ts",
    "db:studio": "pnpm drizzle-kit studio",
    "db:generate": "pnpm drizzle-kit generate",
    "db:reset:full": "pnpm db:reset && sleep 5 && pnpm db:push",
    "clean": "rm -rf .next && pnpm start:dev",
    "fresh": "rm -rf .next node_modules pnpm-lock.yaml && pnpm install && pnpm start:dev",
    "prepare": "husky",
    "precommit": "talisman --githook pre-commit",
    "talisman:check": "talisman --scan",
    "seo:generate": "tsx src/features/seo/scripts/generate-seo-data.ts",
    "seo:import-catnat": "tsx src/features/seo/catnat/scripts/import-catnat.ts",
    "seed:staging": "tsx scripts/seed/seed-staging.ts",
    "fix:epci": "tsx scripts/ops/fix-missing-epci.ts",
    "audit:parcours-ds": "tsx scripts/ops/audit-parcours-ds-integrity.ts",
    "fix:double-progression": "tsx scripts/ops/fix-double-progression-amo.ts",
    "rga:import": "tsx scripts/import/rga-zones/import-rga-zones.ts"
  },
  "dependencies": {
    "@getbrevo/brevo": "4.0.1",
    "@gouvfr/dsfr": "1.14.4",
    "@gouvfr/dsfr-chart": "2.0.4",
    "@react-email/components": "1.0.12",
    "@react-email/render": "2.0.8",
    "@socialgouv/matomo-next": "1.13.1",
    "@types/pg": "8.20.0",
    "argon2": "0.44.0",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "exceljs": "~4.4.0",
    "maplibre-gl": "5.24.0",
    "next": "15.5.18",
    "nodemailer": "8.0.10",
    "pmtiles": "4.4.1",
    "postgres": "3.4.9",
    "prettier": "3.8.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "zod": "3.25.20",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.13.5",
    "@types/nodemailer": "8.0.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.4",
    "@vitest/ui": "4.1.8",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.0",
    "eslint-config-next": "15.5.6",
    "husky": "9.1.7",
    "jsdom": "26.1.0",
    "postcss": "8.5.15",
    "tailwindcss": "4.3.0",
    "ts-node": "10.9.2",
    "vitest": "4.1.8"
  }
}
